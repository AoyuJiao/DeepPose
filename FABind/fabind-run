#!/bin/bash

# --- 0. 路径与环境锚定 ---
FABIND_TOOL_DIR="$HOME/FABind/FABind/fabind"
CKPT_PATH="$HOME/FABind/FABind/ckpt/best_model.bin"
CONDA_ENV_NAME="fabind"

# 获取 Conda 环境
CONDA_BASE=$(conda info --base)
source "${CONDA_BASE}/etc/profile.d/conda.sh"

MAX_CORES=$(nproc)
CURRENT_DIR=$(pwd)

echo "========= FABind 自动化对接工具 (单节点版 by AoyuJiao) ========="

# --- 1. 交互式输入 ---
read -p "请输入实验总路径 [默认: $CURRENT_DIR]: " BASE_INPUT_PATH
BASE_INPUT_PATH=${BASE_INPUT_PATH:-$CURRENT_DIR}
ABS_BASE_PATH=$(readlink -f "$BASE_INPUT_PATH")

read -p "请输入并行核心数 [默认: $MAX_CORES]: " NUM_THREADS
NUM_THREADS=${NUM_THREADS:-$MAX_CORES}

# --- 2. 逻辑分发中心 ---
execute_docking() {
    local WORK_DIR=$1
    local THREADS=$2
    
    echo "------------------------------------------------"
    echo "正在处理目录: $WORK_DIR"
    
    # 定义子路径
    local INDEX_CSV="${WORK_DIR}/index.csv"
    local PDB_FILE_DIR="${WORK_DIR}/pdb_files"
    local SAVE_PT_DIR="${WORK_DIR}/temp_files"
    local SAVE_MOLS_DIR="${SAVE_PT_DIR}/mol"
    local OUTPUT_DIR="${WORK_DIR}/inference_output"

    # 创建必要目录
    mkdir -p "${SAVE_MOLS_DIR}" "${OUTPUT_DIR}"

    # 进入工具目录执行
    cd "$FABIND_TOOL_DIR" || return

    echo ">>> [1/3] 预处理分子..."
    python inference_preprocess_mol_confs.py --index_csv "${INDEX_CSV}" --save_mols_dir "${SAVE_MOLS_DIR}" --num_threads "${THREADS}"
    
    echo ">>> [2/3] 预处理蛋白质..."
    python inference_preprocess_protein.py --pdb_file_dir "${PDB_FILE_DIR}" --save_pt_dir "${SAVE_PT_DIR}"

    echo ">>> [3/3] 开始推理..."
    python fabind_inference.py --ckpt "${CKPT_PATH}" --batch_size 4 --seed 128 --test-gumbel-soft --redocking --post-optim --write-mol-to-file --sdf-output-path-post-optim "${OUTPUT_DIR}" --index-csv "${INDEX_CSV}" --preprocess-dir "${SAVE_PT_DIR}" --sdf-to-mol2
}

# --- 3. 模式识别 ---
conda activate "$CONDA_ENV_NAME"

if [ -f "${ABS_BASE_PATH}/index.csv" ]; then
    # 模式 A: 当前目录即是工作目录
    echo "检测到当前路径下存在 index.csv，启动单路径模式。"
    execute_docking "$ABS_BASE_PATH" "$NUM_THREADS"
else
    # 模式 B: 扫描子文件夹
    echo "当前路径未发现 index.csv，正在扫描子文件夹..."
    SUB_DIRS=()
    for d in "${ABS_BASE_PATH}"/*/; do
        if [[ -f "${d}index.csv" && -d "${d}pdb_files" ]]; then
            SUB_DIRS+=("$d")
        fi
    done

    if [ ${#SUB_DIRS[@]} -eq 0 ]; then
        echo "错误: 未找到包含 index.csv 和 pdb_files 的有效工作目录。"
        conda deactivate
        exit 1
    fi

    echo "发现以下 ${#SUB_DIRS[@]} 个有效任务目录:"
    for dir in "${SUB_DIRS[@]}"; do echo "  - $(basename "$dir")"; done

    read -p "是否逐个进行对接？ [Y/n]: " CONFIRM
    CONFIRM=${CONFIRM:-"Y"}

    if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
        for dir in "${SUB_DIRS[@]}"; do
            execute_docking "$(readlink -f "$dir")" "$NUM_THREADS"
        done
    else
        echo "用户取消任务。"
        conda deactivate
        exit 0
    fi
fi

# --- 4. 结束 ---
conda deactivate
cd "$CURRENT_DIR"
echo "=========================================="
echo "所有对接任务已完成！"
